{
  "app": ".venv/bin/python app.py",
  "context": {
    "project": "segurimax",
    "env_name": "dev",
    "github": {
      "owner": "mijailmolgar123",
      "repo": "proyecto-cotizaciones",
      "branch": "ajustes_bd"
    },
    "environments": {
      "dev": {
        "region": "us-east-1",
        "vpc_cidr": "10.0.0.0/16",
        "public_subnet_cidr_mask": 24,
        "private_subnet_cidr_mask": 24,
        "max_azs": 2,
        "instance_type": "t3.micro",
        "associate_elastic_ip": true,
        "allow_https": false,
        "ssh_cidr": "",
        "ssh_key_name": "",
        "app_deploy_key_parameter_name": "/proyecto-cotizaciones/dev/github/deploy-key",
        "app_config_parameter_prefix": "/segurimax/dev/app-config",
        "app_directory": "/home/ec2-user/app",
        "app_service_name": "myapp",
        "app_flask_app": "app:create_app",
        "app_env_file_path": "/etc/myapp.env",
        "app_port": 8000,
        "app_system_packages": [
          "nginx",
          "git",
          "python3.11",
          "python3.11-pip",
          "postgresql17",
          "pango",
          "gdk-pixbuf2",
          "cairo",
          "fontconfig",
          "libffi"
        ],
        "db_name": "proyecto_cotizaciones",
        "db_username": "postgres",
        "db_instance_class": "t4g.micro",
        "db_engine_version": "17.4",
        "db_allocated_storage": 20,
        "db_max_allocated_storage": 100,
        "db_backup_days": 1,
        "db_publicly_accessible": false,
        "db_deletion_protection": false,
        "schedule_timezone": "America/Lima",
        "business_start_hour": 8,
        "business_stop_hour": 21,
        "scheduler_enabled": true
      },
      "prod": {
        "region": "us-east-1",
        "vpc_cidr": "10.1.0.0/16",
        "public_subnet_cidr_mask": 24,
        "private_subnet_cidr_mask": 24,
        "max_azs": 2,
        "instance_type": "t3.micro",
        "associate_elastic_ip": true,
        "allow_https": false,
        "ssh_cidr": "",
        "ssh_key_name": "",
        "app_deploy_key_parameter_name": "/your-app/prod/github/deploy-key",
        "app_config_parameter_prefix": "/segurimax/prod/app-config",
        "app_directory": "/home/ec2-user/app",
        "app_service_name": "myapp",
        "app_flask_app": "app:create_app",
        "app_env_file_path": "/etc/myapp.env",
        "app_port": 8000,
        "app_system_packages": [
          "nginx",
          "git",
          "python3.11",
          "python3.11-pip",
          "postgresql17",
          "pango",
          "gdk-pixbuf2",
          "cairo",
          "fontconfig",
          "libffi"
        ],
        "db_name": "proyecto_cotizaciones",
        "db_username": "postgres",
        "db_instance_class": "t4g.micro",
        "db_engine_version": "17.4",
        "db_allocated_storage": 20,
        "db_max_allocated_storage": 100,
        "db_backup_days": 7,
        "db_publicly_accessible": false,
        "db_deletion_protection": true,
        "schedule_timezone": "America/Lima",
        "business_start_hour": 8,
        "business_stop_hour": 21,
        "scheduler_enabled": true
      }
    }
  }
}
